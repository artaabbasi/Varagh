{
  "name": "@varagh/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs --external:bufferutil --external:utf-8-validate",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@varagh/shared": "workspace:*",
    "express": "^4.18.3",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
