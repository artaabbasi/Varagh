# Production build settings (committed — safe to share).
# Vite loads this file on top of .env when NODE_ENV=production (i.e. vite build).
#
# Leave VITE_SERVER_URL empty so the built app connects to the same origin
# that served the page.  In Docker, nginx sits on that origin and proxies
# /socket.io/ requests back to the Node server container.
VITE_SERVER_URL=https://varagh-server.artanova.top
