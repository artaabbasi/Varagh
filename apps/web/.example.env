# Socket.IO server URL.
# Leave empty to use Vite's proxy (recommended for local dev — the proxy
# forwards /socket.io from whatever IP the browser used to reach the page).
# Set to an explicit URL when the server runs on a different machine, e.g.:
#   VITE_SERVER_URL=http://192.168.1.42:3001
VITE_SERVER_URL=http://192.168.1.18:3001
