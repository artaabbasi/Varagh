{
  "name": "varagh",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"pnpm --filter @varagh/server dev\" \"pnpm --filter @varagh/web dev\"",
    "build": "pnpm --filter @varagh/shared build && pnpm --filter @varagh/server build && pnpm --filter @varagh/web build",
    "build:server": "pnpm --filter @varagh/server build:bundle",
    "deploy": "bash scripts/deploy.sh",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
